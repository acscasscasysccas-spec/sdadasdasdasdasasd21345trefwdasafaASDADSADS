function dezz.ui.ColorPicker(cfg, par, onChange)
    local b = vgui.Create("UCPicker", par)
    b.Color = string.ToColor(dezz.cfg.colors[cfg] or "255 255 255 255")

    function b:DoClick()
        local x, y = self:LocalToScreen(0, self:GetTall())

        if IsValid(dezz.ui.ColorWindow) then
            dezz.ui.ColorWindow:Remove()
        end

        dezz.ui.ColorWindow = vgui.Create("UColorPanel")
        dezz.ui.ColorWindow:SetPos(x+25, y-100)
        dezz.ui.ColorWindow:SetSize(200, 200)

        dezz.ui.ColorWindow:SetAlpha(0)
        dezz.ui.ColorWindow:AlphaTo(255, 0.2, 0, function() end)

        local c = vgui.Create("UColorMixer", dezz.ui.ColorWindow)
        c:Dock(FILL)
        c:SetColor(b.Color)
        
        c.HSV.Knob:SetSize(5, 5)
        
        function c.HSV.Knob:Paint(w, h)
            surface.SetDrawColor(b.Color.r, b.Color.g, b.Color.b, 255)
            surface.DrawRect(0, 0, w, h)
            surface.SetDrawColor(dezz.Colors[255] or color_white)
            surface.DrawOutlinedRect(0, 0, w, h, 1)
        end

        function c:ValueChanged(col)
            b.Color = col
            dezz.cfg.colors[cfg] = string.format("%d %d %d %d", col.r, col.g, col.b, col.a)
            if onChange then 
                onChange(col) 
            end
            
            if IsValid(b) then
                b:SetColor(col)
            end
        end
    end

    function b:SetColor(col)
        self.Color = col
        self:SetTooltip(string.format("R: %d G: %d B: %d A: %d", col.r, col.g, col.b, col.a))
    end

    b:SetColor(b.Color)
    
    return b
end

