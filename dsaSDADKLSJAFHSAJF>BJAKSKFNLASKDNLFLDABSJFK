local function IsPlayerTracked(ply)
    if not IsValid(ply) then return false end
    local sid = ply:SteamID()
    return sid and dezz.trackedPlayers[sid]
end

hook.Add("NotifyShouldTransmit", "dezz_TrackPlayerJoin", function(ent, shouldTransmit)
    if not shouldTransmit or not IsValid(ent) or not ent:IsPlayer() then return end
    if IsPlayerTracked(ent) then
        dezz.cfg.priorityList[ent:SteamID()] = true
        
        dezz.knownTrackedPlayers[ent] = true
        if not dezz.alreadyNotified[ent] then
            dezz.alreadyNotified[ent] = true
            chat.AddText(
                Color(255, 100, 100), "[dezzaster] ",
                Color(255, 0, 0), "[CHEAT USER]: ",
                Color(255, 255, 255), ent:Nick(),
                Color(255, 2, 5), " РҝРҫРҙРәР»СҺСҮРёР»СҒСҸ."
            )
        end
