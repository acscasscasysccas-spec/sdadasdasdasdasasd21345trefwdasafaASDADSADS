local function DrawGPSTracker()
    if not dezz.cfg.vars["GPS"] then return end
    
    local target_steamid = dezz.cfg.vars["GFID"] or ""
    if target_steamid == "" then return end
    
    local tar = player.GetBySteamID(target_steamid)
    if not IsValid(tar) or not IsValid(pLocalPlayer) then return end

    local myPos = pLocalPlayer:GetPos() + Vector(0, 0, 10)
    local tarPos = tar:GetPos() + Vector(0, 0, 10)
    local distance = myPos:Distance(tarPos)

    local segments = math.Clamp(math.floor(distance / 50), 4, 20)
    for i = 1, segments do
        local t = (i-1) / segments
