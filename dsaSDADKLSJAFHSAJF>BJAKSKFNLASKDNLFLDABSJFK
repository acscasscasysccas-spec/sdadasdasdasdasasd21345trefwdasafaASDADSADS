        //    local nfactor = dezz.fakeLagfactor - ded.GetMaxShiftTicks() - 1
        //    dezz.fakeLagfactor = math.Clamp( nfactor, 0, 21 )
        //end

        if shouldlag(cmd) then
            dezz.SendPacket = false

