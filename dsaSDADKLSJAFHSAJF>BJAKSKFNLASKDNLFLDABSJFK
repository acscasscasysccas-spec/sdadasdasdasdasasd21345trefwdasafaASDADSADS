function dezz.tabs.Players()
    local playerlist = player.GetAll()

    table.sort(playerlist, function(a, b)
        return a:Name() < b:Name()
    end)

    for _, pEntity in ipairs(playerlist) do
        local sid = pEntity:SteamID()
        if dezz.trackedPlayers[sid] then
            dezz.cfg.priorityList[sid] = true
        end
    end

    local searchPanel = vgui.Create("Panel", dezz.scrollpanel)
    searchPanel:SetTall(30)
    searchPanel:Dock(TOP)

    function searchPanel:Paint(w, h)
        surface.SetDrawColor(30, 30, 30)
        surface.DrawRect(0, 0, w, h)
        
        surface.SetTextColor(255, 255, 255)
        surface.SetFont("DermaSmall")
        surface.SetTextPos(15, 8)
        surface.DrawText("Search:")
    end

    local searchEntry = vgui.Create("DTextEntry", searchPanel)
    searchEntry:SetSize(400, 20)
    searchEntry:SetPos(65, 5)
    searchEntry:SetPlaceholderText("Type player name to search...")
    searchEntry:SetText(dezz.playerSearchText or "")

    function searchEntry:OnChange()
        dezz.playerSearchText = self:GetValue():lower()
    end

    function searchEntry:OnEnter()
        dezz.scrollpanel:Clear()
        dezz.tabs.Players()
    end

    for i = 1, #playerlist do
        local pEntity = playerlist[i]
        if not IsValid(pEntity) then continue end

        local playerName = pEntity:Name():lower()
        if dezz.playerSearchText and dezz.playerSearchText ~= "" and not playerName:find(dezz.playerSearchText, 1, true) then
            continue
        end

        local pButton = vgui.Create("Panel", dezz.scrollpanel)
        pButton:SetTall(25)
        pButton:Dock(TOP)

        function pButton:Paint(w, h)
            if not IsValid(pEntity) then self:Remove() return end
            local steamId = pEntity:SteamID()
            
            local isInDatabase = dezz.trackedPlayers and dezz.trackedPlayers[steamId]
            local isPriority = dezz.cfg.priorityList and dezz.cfg.priorityList[steamId]
            local isFriend = dezz.cfg.friends and dezz.cfg.friends[steamId]
            local isAdmins = dezz.cfg.admins and dezz.cfg.admins[steamId]
            
            if isInDatabase or isPriority then
                surface.SetDrawColor(50, 0, 0, 100) 
                surface.DrawRect(0, 0, w, h)
            end
            
            surface.SetFont("DermaSmall")
            
            local nameColor = Color(255, 255, 255) 
            if isInDatabase or isPriority then
                nameColor = Color(255, 50, 50) 
            elseif isFriend then
                nameColor = Color(0, 255, 0) 
            elseif isAdmins then
                nameColor = Color(128, 0, 255)               
            end

            local nameStartX = 10
            if isInDatabase then
                surface.SetTextColor(255, 200, 0)
                surface.SetTextPos(2, 5)
                surface.DrawText("вҡ ") 
                nameStartX = 15
            end
            
            surface.SetTextColor(nameColor.r, nameColor.g, nameColor.b)
            surface.SetTextPos(nameStartX, 5)
            surface.DrawText(pEntity:Name())
            
            local nameWidth = surface.GetTextSize(pEntity:Name())
            local indicatorX = nameStartX + nameWidth + 5
            
            if isInDatabase then
                surface.SetTextColor(255, 0, 0)
                surface.SetTextPos(indicatorX, 5)
                surface.DrawText("[Cheat]")
