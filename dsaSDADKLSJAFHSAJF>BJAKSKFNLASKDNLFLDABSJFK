        if dezz.cfg.vars["Hitmarker"] and #dezz.hitmarkers > 0 then
            local hm = string.ToColor(dezz.cfg.colors["Hitmarker"])
            local currentTime = CurTime()
            
            for i = #dezz.hitmarkers, 1, -1 do
                local hit = dezz.hitmarkers[i]

                if hit.time < currentTime - 0.8 then 
                    table.remove(dezz.hitmarkers, i) 
                    continue 
                end 
                
                local elapsed = currentTime - hit.time
                local centerX, centerY = screenWidth * 0.5, screenHeight * 0.5
                
                local spreadProgress = math.min(elapsed / 0.3, 1.0)
                local alphaProgress = 1.0 - math.max(0, (elapsed - 0.5) / 0.3)

                local spread = 80 * spreadProgress
                local length = 13.5 * (1 - spreadProgress * 0.5)
                local alpha = 255 * alphaProgress

                local function drawHitmarkerLine(x1, y1, x2, y2)
                    surface.SetDrawColor(hm.r, hm.g, hm.b, alpha)
                    surface.DrawLine(x1, y1, x2, y2)

                    surface.SetDrawColor(0, 0, 0, 100 * alphaProgress)
                    surface.DrawLine(x1 - 1, y1 - 1, x2 - 1, y2 - 1)
                end

                drawHitmarkerLine(centerX - spread, centerY - spread, centerX - spread - length, centerY - spread - length)
                drawHitmarkerLine(centerX + spread, centerY - spread, centerX + spread + length, centerY - spread - length)
                drawHitmarkerLine(centerX - spread, centerY + spread, centerX - spread - length, centerY + spread + length)
                drawHitmarkerLine(centerX + spread, centerY + spread, centerX + spread + length, centerY + spread + length)
                end
            end
        end

