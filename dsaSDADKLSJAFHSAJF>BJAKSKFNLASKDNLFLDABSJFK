function dezz.PrePlayerDraw(pEntity, iFlags)
    if pEntity == pLocalPlayer then
        return 
    end

    pEntity:AnimResetGestureSlot(GESTURE_SLOT_VCD)
    pEntity:AnimResetGestureSlot(GESTURE_SLOT_CUSTOM)

    pEntity:SetPoseParameter("head_pitch", 0)
    pEntity:SetPoseParameter("head_yaw", 0)

    if dezz.cfg.vars["Resolver"] then
        local shots = pEntity.aimshots or 0
        local data = dezz.player_data and dezz.player_data[pEntity:EntIndex()]
        local base_yaw = pEntity:EyeAngles().y
        
        if not dezz.player_data then 
            dezz.player_data = {} 
        end

        if not dezz.player_data[pEntity:EntIndex()] then
            dezz.player_data[pEntity:EntIndex()] = {}
        end

        data = dezz.player_data[pEntity:EntIndex()]

        if data and data.last_angles and #data.last_angles > 0 then
            local idx = (data.brute_stage or 0) % #data.last_angles + 1
            base_yaw = data.last_angles[idx]
        end

        local brute_modes = {
            ["Absolute"] = { -90, 0, 90, 180 },
            ["Rage"] = { 0, -30, 30, -60, 60, -90, 90, -120, 120, -150, 150, -179, 179 },
            ["Legit"] = { 0, -15, 15, -30, 30, -45, 45 },
            ["Delta"] = { 0, -60, 60, -90, 90, -120, 120, -150, 150, -179, 179 },
            ["Experimental"] = { math.random(-179, 179) },
            ["HVH"] = { -180, -135, -90, -45, 0, 45, 90, 135, 179, -179, -120, -60, 60, 120, 160, -160 }
        }
        
        local mode = dezz.cfg.vars["Resolver type"] or "Absolute"

        if dezz.cfg.vars["Adaptive resolver"] and mode != "Experimental" and mode != "HVH" then
            local vel = (pEntity.GetVelocity and pEntity:GetVelocity():Length2D()) or 0
            local crouch = (pEntity.Crouching and pEntity:Crouching()) or false
            local onground = (pEntity.IsOnGround and pEntity:IsOnGround()) or true

            if not onground then
                mode = "Delta"
            elseif vel > 120 and not crouch then
                mode = "Rage"
            elseif crouch and vel < 10 then
                mode = "Legit"
            else
                mode = "Absolute"
            end
        end

        local deltas = brute_modes[mode] or brute_modes["Absolute"]

        if mode == "Experimental" then
            local rand = math.random(-179, 179)
            local final_yaw = math.NormalizeAngle(base_yaw + rand)
            local angs = Angle(0, final_yaw, 0)
            pEntity:SetRenderAngles(angs)
            pEntity:SetPoseParameter("move_yaw", angs.y)
            pEntity:InvalidateBoneCache()
            pEntity:SetupBones()
            return
        end

        if mode == "HVH" then
            local tick = engine.TickCount()
            local entropy = pEntity:EntIndex() * 17 + tick * 0.01
            local dynamic_offset = math.sin(CurTime() * 2 + entropy) * 120
            local static_offsets = { -180, -90, 0, 90, 180 }
            
            local current_stage = (shots % 3)
            local final_offset = 0
            
            if current_stage == 0 then
                final_offset = dynamic_offset
            elseif current_stage == 1 then
                final_offset = static_offsets[(tick % #static_offsets) + 1]
            else
                final_offset = brute_modes.HVH[(shots % #brute_modes.HVH) + 1]
            end
            
            local final_yaw = math.NormalizeAngle(base_yaw + final_offset)
            local angs = Angle(0, final_yaw, 0)
            pEntity:SetRenderAngles(angs)
            pEntity:SetPoseParameter("move_yaw", angs.y)
            pEntity:InvalidateBoneCache()
            pEntity:SetupBones()
            return
        end

        local brute_idx = (shots % #deltas) + 1
        local final_yaw = base_yaw + deltas[brute_idx]
        final_yaw = math.NormalizeAngle(final_yaw)

        local angs = Angle(0, final_yaw, 0)
        pEntity:SetRenderAngles(angs)
        pEntity:SetPoseParameter("move_yaw", angs.y)
    end

    if dezz.cfg.vars["Taunt resolver"] and pEntity:IsValid() and pEntity:GetNWBool("IsTaunting", false) then
        local tauntYaw = nil

        if pEntity.GetVelocity and pEntity:GetVelocity():Length2D() > 5 then
            local vel = pEntity:GetVelocity()
            tauntYaw = math.deg(math.atan2(vel.y, vel.x))
        elseif pEntity.EyeAngles then
            tauntYaw = pEntity:EyeAngles().y
        end

        if tauntYaw then
            local angs = pEntity:GetRenderAngles() or Angle()
            angs.y = tauntYaw
            pEntity:SetRenderAngles(angs)
        end

        if pEntity.SetPoseParameter then
            pEntity:SetPoseParameter("aim_pitch", 0)
            pEntity:SetPoseParameter("head_pitch", 0)
        end
    end

    if dezz.cfg.vars["Pitch resolver"] and pEntity.fakepitch then
        pEntity:SetPoseParameter("aim_pitch", -89)
        pEntity:SetPoseParameter("head_pitch", -89)
    end
    
    pEntity:InvalidateBoneCache()
    pEntity:SetupBones()

    pEntity.ChatGestureWeight = 0
end

