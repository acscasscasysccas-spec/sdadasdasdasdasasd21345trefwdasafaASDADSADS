dezz.cfgTable = {}

function dezz.fillConfigTable()
    local ftbl = file.Find("dezzaster/*.txt", "DATA")
    dezz.cfgTable = {}

    if not ftbl or #ftbl == 0 then return end

    for i = 1, #ftbl do
        local str = ftbl[i] 
        local len = string.len(str)
        local f = string.sub(str, 1, len - 4) -- Remove .txt extension

        dezz.cfgTable[#dezz.cfgTable + 1] = f
    end
end

dezz.fillConfigTable()

function dezz.SaveConfig()
    local tojs = util.TableToJSON(dezz.cfg, false)
    local str = dezz.cfgTable[dezz.cfg.vars["Selected config"]]

    if str then
        file.Write("dezzaster/" .. str .. ".txt", tojs)
    else
        print("Error: Selected config not found.")
    end
end

function dezz.LoadConfig()
    local str = dezz.cfgTable[dezz.cfg.vars["Selected config"]]
    //print(dezz.cfg.vars["Selected config"])

    if not str or not file.Exists("dezzaster/" .. str .. ".txt", "DATA") then
        print("Error: Config file not found.")
        return
    end

    local read = file.Read("dezzaster/" .. str .. ".txt", "DATA")
    local totbl = util.JSONToTable(read)
    if not totbl then
        print("Error: Failed to parse config file.")
        return
    end

    local ConfigName = dezz.cfg.vars["Config name"]
    local SelectedConfig = dezz.cfg.vars["Selected config"]

dezz.cfg.friends = {}
dezz.cfg.ents = {}
dezz.cfg.binds = {}
dezz.cfg.priorityList = {}
dezz.cfg.admins = {}

if type(totbl) != "table" then return end

dezz.cfg = dezz.cfg or {}

for category, data in pairs(totbl) do
    if type(data) == "table" then
        local subTableName = string.lower(category)
        if category == "vars" or category == "colors" or category == "binds" or 
           category == "friends" or category == "ents" or category == "priorityList" or 
           category == "Admins" then
            dezz.cfg[subTableName] = dezz.cfg[subTableName] or {}
            for key, value in pairs(data) do
                dezz.cfg[subTableName][key] = value
            end
        else
            for key, value in pairs(data) do
                dezz.cfg[key] = value
            end
        end
    end
end

    dezz.cfg.vars["Config name"] = ConfigName
    dezz.cfg.vars["Selected config"] = SelectedConfig

    ded.SetInterpolation(dezz.cfg.vars["Disable interpolation"])
    ded.SetSequenceInterpolation(dezz.cfg.vars["Disable Sequence interpolation"])
    ded.EnableAnimFix(dezz.cfg.vars["Update Client Anim fix"])
    ded.EnableBoneFix(dezz.cfg.vars["Bone fix"])

    ded.SetMaxShift(dezz.cfg.vars["Charge ticks"])
    ded.SetMinShift(dezz.cfg.vars["Shift ticks"])
    ded.EnableTickbaseShifting(dezz.cfg.vars["Tickbase shift"])
end

function FixAnimations(ply)
    if type(ply) != "Entity" and type(ply) != "Player" then
        return
    end
    
    if ply == true or ply == false then
        return
    end
    
    if not ply or not isentity(ply) then
        return
    end
    
    if not ply:IsValid() then
        return
    end
    
    if not ply:IsPlayer() then
        return
    end
    
    local wep = ply:GetActiveWeapon()
    if wep and wep:IsValid() then
        wep:SendWeaponAnim(ACT_VM_IDLE)
    end
    
    ply:AnimRestartMainSequence()
    ply:AnimRestartGesture(GESTURE_SLOT_ATTACK_AND_RELOAD, true)
    
    ply:SetupBones()
    ply:InvalidateBoneCache()
    
    timer.Simple(0.1, function()
        if not ply or not ply:IsValid() then 
            return 
        end
        
        ply:SetCycle(0)
        ply:SetSequence(0)
        
        for i = 0, 13 do
            if ply:IsValidLayer(i) then
                ply:SetLayerCycle(i, 0)
                ply:SetLayerWeight(i, 1)
            end
        end
    end)
end

function dezz.CreateConfig()
    local str = dezz.cfg.vars["Config name"]

    if str then
        file.Write("dezzaster/" .. str .. ".txt", "")
        dezz.fillConfigTable()
        dezz.initTab("Config")
    else
        print("Error: Config name not specified.")
    end
end

function dezz.DeleteConfig()
    local selectedConfigId = dezz.cfg.vars["Selected config"]
    local str = dezz.cfgTable[selectedConfigId]

    if str then
        file.Delete("dezz/" .. str .. ".txt")

        table.remove(dezz.cfgTable, selectedConfigId)

        if #dezz.cfgTable > 0 then
            dezz.cfg.vars["Selected config"] = 1
        else
            dezz.cfg.vars["Selected config"] = nil
        end

        dezz.fillConfigTable()
        dezz.initTab("Config")
    else
        print("Error: Selected config not found.")
    end
end


function dezz.TIME_TO_TICKS(time)
	return math.floor(0.5 + time / flTickInterval)
end

function dezz.TICKS_TO_TIME(ticks)
    return flTickInterval * ticks
end

function dezz.ROUND_TO_TICK(time)
    return dezz.TICKS_TO_TIME(dezz.TIME_TO_TICKS(time))
end



