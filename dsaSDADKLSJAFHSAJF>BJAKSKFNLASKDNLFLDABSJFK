function dezz.CalcView(ply, origin, angles, fov, znear, zfar)
    if dezz.UnSafeFrame then 
        return { origin = origin, angles = angles, fov = fov } 
    end

    if dezz.cfg.vars["spectating"] then
        local followTarget = player.GetBySteamID(dezz.cfg.vars["Specta"] or "")
        
        if IsValid(followTarget) and followTarget:Alive() then
            return {
                origin = followTarget:EyePos(),
                angles = followTarget:EyeAngles(),
                fov = fov,
                drawviewer = false
            }
        end
    end

    local view = {}

    local tppressed = dezz.IsKeyDown(dezz.cfg.binds["Third person"])
    local fcpressed = dezz.IsKeyDown(dezz.cfg.binds["Free camera"])

    if dezz.cfg.vars["Third person"] and tppressed and not dezz.tptoggled then
        dezz.tpenabled = not dezz.tpenabled
    end

    if dezz.cfg.vars["Free camera"] and fcpressed and not dezz.fctoggled then
        dezz.fcenabled = not dezz.fcenabled
        dezz.fcangles = pLocalPlayer:EyeAngles()
    elseif dezz.fcenabled and not dezz.cfg.vars["Free camera"] then
        dezz.fcenabled = false
    end

    dezz.tptoggled = tppressed
    dezz.fctoggled = fcpressed

    if dezz.cfg.vars["Fake duck"] and dezz.IsKeyDown(dezz.cfg.binds["Fake duck"]) then
        origin.z = pLocalPlayer:GetPos().z + 64
    end

    local fangs = dezz.cfg.vars["Silent aim"] and dezz.SilentAngle or angles

    if dezz.fcenabled then
        local speed = dezz.cfg.vars["Free camera speed"] or 10
        
        if input.IsKeyDown(KEY_W) then
            dezz.fcvector = dezz.fcvector + dezz.SilentAngle:Forward() * speed
        end
        if input.IsKeyDown(KEY_S) then
            dezz.fcvector = dezz.fcvector - dezz.SilentAngle:Forward() * speed
        end
        if input.IsKeyDown(KEY_A) then
            dezz.fcvector = dezz.fcvector - dezz.SilentAngle:Right() * speed
        end
        if input.IsKeyDown(KEY_D) then
            dezz.fcvector = dezz.fcvector + dezz.SilentAngle:Right() * speed
        end
        if input.IsKeyDown(KEY_SPACE) then
            dezz.fcvector.z = dezz.fcvector.z + speed
        end
        if input.IsKeyDown(KEY_LSHIFT) then
            dezz.fcvector.z = dezz.fcvector.z - speed
        end

        view.origin = dezz.fcvector
        view.angles = fangs
        view.fov = dezz.cfg.vars["Fov override"] or fov
        view.drawviewer = not dezz.cfg.vars["Ghetto free cam"]
    else
        dezz.fcvector = origin
        view.origin = dezz.tpenabled and origin - (fangs:Forward() * dezz.cfg.vars["Third person distance"]) or origin

        if dezz.tpenabled and dezz.cfg.vars["Third person collision"] then
            local tr = {
                start = origin,
                endpos = origin - (fangs:Forward() * dezz.cfg.vars["Third person distance"]),
                mins = dezz.cameraHullMin,
                maxs = dezz.cameraHullMax,
                filter = ply,
                mask = MASK_BLOCKLOS
            }

            local res = TraceHull(tr)
            view.origin = res.HitPos
        end

        view.angles = fangs
        view.fov = dezz.cfg.vars["Fov override"] or fov
        view.drawviewer = hook.Call("ShouldDrawLocalPlayer", nil, ply)
    end

    dezz.vieworigin = (dezz.cfg.vars["Ghetto free cam"] and dezz.fcenabled) and dezz.fcvector or origin
    dezz.viewfov = view.fov
    dezz.znear = znear

    if not dezz.cfg.vars["Override view"] then
        if math.floor(fov) ~= GetConVar("fov_desired"):GetFloat() then
            view.fov = fov 
        end

        local pVehicle = pLocalPlayer:GetVehicle()
        if IsValid(pVehicle) then
            view = hook.Run("CalcVehicleView", pVehicle, ply, view) or view
        end

        local pWeapon = pLocalPlayer:GetActiveWeapon()
        if IsValid(pWeapon) and pWeapon.CalcView then
            local weaponOrigin, weaponAngles, weaponFov = pWeapon:CalcView(ply, Vector(view.origin), Angle(view.angles), view.fov)
            view.origin, view.angles, view.fov = weaponOrigin or view.origin, weaponAngles or view.angles, weaponFov or view.fov
        end
    end

    return view
end

function dezz.GetFovRadius()
    local Radius = dezz.cfg.vars["Aimbot FOV"]

    local Ratio = screenWidth / screenHeight
    local AimFOV = Radius * (math.pi / 180)
    local GameFOV = dezz.viewfov * (math.pi / 180)
    local ViewFOV = 2 * math.atan(Ratio * (dezz.znear / 2) * math.tan(GameFOV / 2))



    return (math.tan(AimFOV) / math.tan(ViewFOV / 2)) * screenWidth
end

