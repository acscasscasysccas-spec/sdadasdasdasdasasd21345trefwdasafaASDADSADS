function dezz.CanShoot( cmd )
	if not dezz.activeWeapon then return false end
	local seq = dezz.activeWeapon:GetSequence()

    if dezz.cfg.binds["Aim on key"] != 0 and not dezz.IsKeyDown( dezz.cfg.binds["Aim on key"] ) then
        return false
    end

	if dezz.badSweps[ dezz.activeWeaponClass ] then
		return false
	end

    if dezz.moveType == MOVETYPE_NOCLIP then
        return false
    end

    if dezz.cfg.vars["Auto fire"] and cmd:KeyDown(IN_ATTACK) then
        return false
    end

