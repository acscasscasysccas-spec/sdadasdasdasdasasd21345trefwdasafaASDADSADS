    if not dezz.cfg.vars["Anti aim"] then return false end
    if cmd:KeyDown(IN_ATTACK) then return false end
    if cmd:KeyDown(IN_USE) then return false end
    if dezz.moveType == MOVETYPE_LADDER then return false end
    if dezz.moveType == MOVETYPE_NOCLIP then return false end

    if dezz.cfg.binds["Anti aim"] ~= 0 and not dezz.IsKeyDown(dezz.cfg.binds["Anti aim"]) then
        return false
    end

    return true 
end

function dezz.AntiAim(cmd)
    if not IsValid(pLocalPlayer) or not pLocalPlayer:Alive() then return end
    
    local freestandsucc, freestandsafe, freestandunsafe 

    if dezz.cfg.vars["Freestanding"] then
        freestandsucc, freestandsafe, freestandunsafe = dezz.Freestand(cmd)
    end

    if dezz.SendPacket then
        dezz.SwaySide = dezz.SwaySide * -1 
    end

    baseyaw = dezz.GetBaseYaw()
    local pitch = CalcPitch()
    
    local yawMode = dezz.cfg.vars["Yaw"] or 1
    local yawFunc = dezz.CalcYaw[yawMode]
    
    if not yawFunc then
        yawFunc = dezz.CalcYaw[1]
    end
    
    local success, yaw = pcall(yawFunc, cmd)
    if not success then
        yaw = baseyaw
    end

    if dezz.cfg.vars["Yaw randomisation"] then
        yaw = yaw + math.random(-0.9, 0.9) 
    end 

    if freestandsucc then
        yaw = dezz.SendPacket and freestandunsafe or freestandsafe
    end

    if aacheck(cmd) then
        local pyAngle = Angle(pitch, yaw, 0)

        micromovement(cmd)

        cmd:SetViewAngles(pyAngle)
        dezz.oldYaw = pyAngle.y
    end
end


