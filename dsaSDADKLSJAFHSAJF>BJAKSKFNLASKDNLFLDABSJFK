                movey = ply:GetPoseParameter("move_y"),
            }
            
            if dezz.CS_Model_update then
                dezz.CS_Model_update(ply, ply.fakeModel, tbl)
            end
            
            local groupCount = ply.fakeModel:GetHitBoxGroupCount()
            if groupCount and groupCount > 0 then
                for group = 0, groupCount - 1 do
                    local boxCount = ply.fakeModel:GetHitBoxCount(group)
                    if boxCount and boxCount > 0 then
                        for hitbox = 0, boxCount - 1 do
                            local bone = ply.fakeModel:GetHitBoxBone(hitbox, group)
                            if not bone then continue end
                            
                            local pos, ang = ply.fakeModel:GetBonePosition(bone)
