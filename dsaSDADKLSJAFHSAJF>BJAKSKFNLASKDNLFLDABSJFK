        surface.SetTextPos(w-20, h/2-7)
        surface.SetFont("DermaSmall")
        surface.DrawText(self.open_progress > 0.5 and "в–І" or "в–ј")

        surface.SetDrawColor(dezz.Colors[54])
        surface.DrawOutlinedRect(0, 0, w, h)

        if self:GetText() != "" and self.text_alpha > 0 then
            surface.SetTextColor(dezz.Colors[165].r, dezz.Colors[165].g, dezz.Colors[165].b, self.text_alpha)
            surface.SetFont("DermaSmall")
            surface.SetTextPos(8, h/2 - 7)
            surface.DrawText(self:GetText())
        end
