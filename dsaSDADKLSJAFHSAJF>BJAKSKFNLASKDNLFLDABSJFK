local playerTrail = {}
local trailToggleCooldown = 0
local kills1 = 0

local function UpdatePlayerTrail()
    local ply = pLocalPlayer
    if not ply:Alive() then
        playerTrail = {}
        return
    end
    
    playerTrail[#playerTrail + 1] = ply:GetPos()
    
    if #playerTrail > 100 then
        table.remove(playerTrail, 1)
    end
end

local function DrawPlayerTrail()
    if not dezz.cfg.vars["Player Line"] then return end
    
    local trailCount = #playerTrail
    for i = 1, trailCount - 1 do
        local startPos = playerTrail[i] + Vector(0, 0, 10)
        local endPos = playerTrail[i + 1] + Vector(0, 0, 10)
        local t = i / trailCount
        local hue = Lerp(t, 300, 0)
        local color = HSVToColor(hue, 1, 1)
        render.DrawLine(startPos, endPos, color, true)
    end
end

local function KillEffect(data)
    if not dezz.cfg.vars["Kill effect"] then return end
    
    local victim = Entity(data.entindex_killed)
    local attacker = Entity(data.entindex_attacker)

    if attacker == pLocalPlayer and attacker ~= victim and (victim:IsPlayer() or victim:IsBot()) then 
        local vPoint = pLocalPlayer:GetPos()
        local effectdata = EffectData()
        effectdata:SetOrigin(vPoint)
        effectdata:SetStart(vPoint)
        util.Effect("VortDispel", effectdata)

        local vpos = victim:GetPos()
        local effectdata2 = EffectData()
        local boneName = dezz.cfg.vars["KEF"]
        local boneId = victim:LookupBone(boneName)
        
        if boneId then
            effectdata2:SetOrigin(victim:GetBonePosition(boneId))
        else
            effectdata2:SetOrigin(vpos)
        end
        
        effectdata2:SetMagnitude(5)
        effectdata2:SetScale(3)
        util.Effect("ElectricSpark", effectdata2)
    end
end

local nextTrailUpdate = 0
local panicKeyPressed = false

hook.Add("Think", "DezzPlayerTrailSystem", function()
    local ct = CurTime()
    
    if ct > nextTrailUpdate then
        nextTrailUpdate = ct + 0.01
        UpdatePlayerTrail()
    end
    
    if dezz.IsKeyDown(dezz.cfg.binds["Panic Key"]) and not panicKeyPressed then
        panicKeyPressed = true
        hook.Remove("Think", "DezzPlayerTrailSystem")
        hook.Remove("PostDrawTranslucentRenderables", "DrawPlayerTrail")
        hook.Remove("entity_killed", "KillEffect")
        trailToggleCooldown = ct + 0.5
    elseif not dezz.IsKeyDown(dezz.cfg.binds["Panic Key"]) then
        panicKeyPressed = false
    end
end)

hook.Add("PostDrawTranslucentRenderables", "DrawPlayerTrail", DrawPlayerTrail)

