            for i = #dezz.hitnums, 1, -1 do
                local v = dezz.hitnums[i]
                local curTime = CurTime()

                if v.time < curTime - 1 then 
                    table.remove(dezz.hitnums, i) 
                    continue 
                end 

                surface.SetTextColor(v.crit and c or n)

                local angle = v.angle or math.random() * 2 * math.pi
                local distance = (curTime - v.time) * 150
                
                local offsetX = math.cos(angle) * distance
                local offsetY = math.sin(angle) * distance

                local centerX = screenWidth * 0.5
                local centerY = screenHeight * 0.5

