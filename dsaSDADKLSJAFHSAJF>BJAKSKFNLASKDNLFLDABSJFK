    origin = dezz.vieworigin 
	angles = dezz.cfg.vars["Silent aim"] and dezz.SilentAngle or ang
    
    if (not IsValid(weapon_entity)) then
        return origin, angles
    end

    local weapon_callback = weapon_entity.GetViewModelPosition
    
    if (weapon_callback) then
		local vec_pos, vec_ang = weapon_callback(weapon_entity, origin * 1, angles * 1)
        origin, angles = vec_pos or origin, vec_ang or angles
	end

	weapon_callback = weapon_entity.CalcViewModelView

	if (weapon_callback) then
		local vec_pos, vec_ang = weapon_callback(weapon_entity, viewmodel, prev_origin * 1, prev_angles * 1, origin * 1, angles * 1)
        origin, angles = vec_pos or origin, vec_ang or angles
	end

