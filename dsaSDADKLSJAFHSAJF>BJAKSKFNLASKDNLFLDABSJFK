                    sequence = pLocalPlayer:GetLayerSequence(i),
                    weight = pLocalPlayer:GetLayerWeight(i)
                }
            end
        end

        dezz.fakeAngles.origin = pLocalPlayer:GetNetworkOrigin()
        dezz.fakeAngles.seq = pLocalPlayer:GetSequence()
        dezz.fakeAngles.cycle = pLocalPlayer:GetCycle()
    else
        dezz.realAngle = cmd:GetViewAngles()
    end

    if dezz.cfg.vars["Fake lag Fix"] then
        local players = player.GetAll()
        
        for i = 1, #players do
            local v = players[i]
            
            if v == LocalPlayer() then continue end
            
            local latency = ded.GetLatency(0) + ded.GetLatency(1)
            local fixFactor = dezz.cfg.vars["Fix Factor"] or 1
            local predTime = latency * fixFactor
            
            local ticks = dezz.TIME_TO_TICKS(predTime) or 0
            
            if ticks <= 0 then continue end
            
            ded.StartSimulation(v:EntIndex())
            
            for tick = 1, ticks do
                ded.SimulateTick()
            end
            
            local data = ded.GetSimulationData()
            if data and data.m_vecAbsOrigin then
                v:SetRenderOrigin(data.m_vecAbsOrigin)
                v:SetNetworkOrigin(data.m_vecAbsOrigin)
                v:InvalidateBoneCache()
                v:SetupBones()
            end
            
            ded.FinishSimulation()
        end
    end

    local ply, bone, aimang, backtracking, bttick = dezz.SelectTarget(cmd)

    dezz.targetVector = bone 

    if not aimang then return end

    aimang:Normalize()

    if not dezz.cfg.vars["Enable aimbot"] or not ply then return end

    if dezz.cfg.vars["Forward"] and dezz.cfg.vars["Forwardtrack time"] > 0 then
        local targetVel = ply:GetVelocity()
        if targetVel then
            local predictionTime = dezz.cfg.vars["Forwardtrack time"] / 1000
            local aimPos = bone or ply:GetPos()

            aimPos = aimPos + (targetVel * predictionTime)

            local localPos = pLocalPlayer:GetShootPos()
            aimang = (aimPos - localPos):Angle()
            aimang:Normalize()
        end
    end

    local targetTime = ded.GetSimulationTime(ply:EntIndex())
    local timeOffset = ded.GetServerTime(cmd) - targetTime

    local serverArriveTick = ded.GetServerTime(cmd) + ded.GetLatency(0) + ded.GetLatency(1)
    local diff = serverArriveTick - targetTime

    if diff > 1 and dezz.cfg.vars["Adjust tickcount"] then return end

    if dezz.cfg.vars["Always backtrack"] and not backtracking then return end

    if dezz.cfg.vars["Fov limit"] then
        local fov = dezz.cfg.vars["Aimbot FOV"]
        local view = dezz.cfg.vars["Silent aim"] and dezz.SilentAngle or cmd:GetViewAngles()
        local angDiff = aimang - view
        
        angDiff:Normalize()
        
        local fovDiff = math.sqrt(angDiff.x * angDiff.x + angDiff.y * angDiff.y)
        
        if fovDiff > fov then
            dezz.targetVector = false
            return 
        end
    end

    if not dezz.CanShoot(cmd) then return end

    if dezz.cfg.vars["Wait for simulation"] and ply:GetVelocity():Length() ~= 0 and not ply.simtime_updated then
        return 
    end

    if not dezz.cfg.vars["Aimbot smoothing"] and dezz.SkipCommand then return end

    dezz.aimingrn = true

    local altfire = false
    local canstab, rightstab = dezz.CanStab(ply, bone, ply:Health())

    if dezz.cfg.vars["Knifebot"] and canstab then
        altfire = rightstab
    elseif dezz.cfg.vars["Knifebot"] and not canstab then
        return 
    end

    local finalAngle = Angle(aimang)

    if dezz.cfg.vars["Norecoil"] then
        finalAngle = dezz.NoRecoil(finalAngle)
    end

    if dezz.cfg.vars["Nospread"] then
        finalAngle = dezz.NoSpread(cmd, finalAngle)
    end

    if dezz.cfg.vars["On shot aa"] then
        finalAngle.p = -finalAngle.p - 180
        finalAngle.y = finalAngle.y + 180
    end

    if dezz.cfg.vars["Try Predict"] then
        if dezz.targetVector and IsValid(ply) then
            local localPlayer = LocalPlayer()
            local localPos = localPlayer:GetShootPos()
            local targetPos = dezz.targetVector
            
            local targetVel = ply:GetVelocity()
            local targetSpeed = targetVel:Length()
            
            local distance = localPos:Distance(targetPos)
            local bulletSpeed = 8000
            local travelTime = distance / bulletSpeed
            
            local predictedPos = targetPos + (targetVel * travelTime)
            
            local ping = ded.GetLatency(0) + ded.GetLatency(1)
            predictedPos = predictedPos + (targetVel * ping)
            
            local predictedAng = (predictedPos - localPos):Angle()
            predictedAng:Normalize()
            
            finalAngle = predictedAng
        end
    end

    if dezz.cfg.vars["Facestab"] then
        local angles = ply:EyeAngles()
        finalAngle.y = angles.y
        finalAngle.p = angles.p
        altfire = true
    end

    if dezz.cfg.vars["Aimbot smoothing"] then
        local va = cmd:GetViewAngles()
        va.r = 0
        local rat = dezz.cfg.vars["Smoothing"] * 100
        finalAngle = LerpAngle(FrameTime() * rat, va, finalAngle)
    end

    if dezz.cfg.vars["Projectile aimbot"] then
        local distance = pLocalPlayer:EyePos():Distance(ply:GetPos())
        local predTime = math.ceil(distance / 60)
        
        ded.StartSimulation(ply:EntIndex())
        
        for tick = 1, predTime do
            ded.SimulateTick()
        end
        
        local data = ded.GetSimulationData()
        local vec = data.m_vecAbsOrigin
        
        ded.FinishSimulation()
        
        local gravityOffset = predTime * 0.111
        vec.z = vec.z + gravityOffset
        
        finalAngle = (vec - pLocalPlayer:EyePos()):Angle()
        finalAngle:Normalize()
    end

    if dezz.cfg.vars["Facestab"] then
        cmd:SetViewAngles(finalAngle)
        ded.SetContextVector(cmd, aimang:Forward(), true)
    elseif dezz.cfg.vars["pSilent"] then
        ded.SetContextVector(cmd, finalAngle:Forward(), true)
    else
        cmd:SetViewAngles(finalAngle)
    end

    if backtracking then
        targetTime = dezz.btrecords[ply][bttick].simulationtime
        timeOffset = dezz.flServerTime - targetTime
        
        serverArriveTick = dezz.flServerTime + ded.GetLatency(0) + ded.GetLatency(1)
        diff = serverArriveTick - dezz.btrecords[ply][bttick].simulationtime
        
        if diff < 0.2 then
            ded.NetSetConVar("cl_interpolate", "0")
            ded.NetSetConVar("cl_interp", "0")
            local tick = dezz.TIME_TO_TICKS(targetTime)
            ded.SetCommandTick(cmd, tick)
        else
            ded.NetSetConVar("cl_interpolate", "1")
            ded.NetSetConVar("cl_interp", tostring(dezz.flServerTime - targetTime))
            local tick = dezz.TIME_TO_TICKS(dezz.flServerTime)
            ded.SetCommandTick(cmd, tick - 1)
        end
    elseif dezz.cfg.vars["Adjust tickcount"] and ply.simtime_updated then
        local flSimulationTime = ded.GetSimulationTime(ply:EntIndex())
        local iTickCount = dezz.TIME_TO_TICKS(flSimulationTime)
        
        ded.NetSetConVar("cl_interpolate", "0")
        ded.NetSetConVar("cl_interp", "0")
        
        ded.SetCommandTick(cmd, iTickCount)
    end
    
    if dezz.cfg.vars["Auto fire"] then
        if string.StartsWith(dezz.activeWeaponClass, "m9k_") then
            cmd:RemoveKey(IN_SPEED)
        end
        
        dezz.SendPacket = true
        pLocalPlayer.simtime_updated = true
        
        if dezz.cfg.vars["Resolver"] then 
            ply.aimshots = (ply.aimshots or 0) + 1
        end
        
        local isAutomatic = true
        
        if dezz.activeWeapon.Primary then
            isAutomatic = dezz.activeWeapon.Primary.Automatic
        else
            if dezz.activeWeaponClass == "weapon_pistol" then
                isAutomatic = false
            end
        end
        
        if altfire or (dezz.cfg.vars["Alt Rapid fire"] and cmd:CommandNumber() % 2 == 0) then
            cmd:AddKey(IN_ATTACK2)
        else
            if isAutomatic or (dezz.cfg.vars["Rapid fire"] and cmd:CommandNumber() % 2 == 0) then
                cmd:AddKey(IN_ATTACK)
            end
        end
        
        dezz.SkipCommand = true
    end
    
    return true
end

