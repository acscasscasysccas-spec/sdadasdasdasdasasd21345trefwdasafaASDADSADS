    local function Drawlineplayers()
        if not dezz.cfg.vars["line"] or not dezz.tpenabled then return end
        
        local myPos = pLocalPlayer:GetPos() + Vector(0, 0, 45)

        cam.IgnoreZ(true)
        
        for _, target in ipairs(player.GetAll()) do
            if target == pLocalPlayer or not target:Alive() then continue end
            
            local targetPos = target:GetPos() + Vector(0, 0, 45)
            local distance = myPos:Distance(targetPos)

            local segments = math.Clamp(math.floor(distance / 50), 4, 20)
            for i = 1, segments do
                local t = (i - 1) / segments
                local startPos = LerpVector(t, myPos, targetPos)
                local endPos = LerpVector(i / segments, myPos, targetPos)
                local colorStr = dezz.cfg.colors["cline"] or "255 255 255 255"
                local r, g, b, a = string.match(colorStr, "(%d+) (%d+) (%d+) (%d+)")
                local lineColor = Color(tonumber(r), tonumber(g), tonumber(b), tonumber(a))
                
                render.DrawLine(startPos, endPos, lineColor, true)
            end
        end

        cam.IgnoreZ(false)
    end

