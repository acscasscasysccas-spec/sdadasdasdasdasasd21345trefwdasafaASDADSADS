            "https://cdn.discordapp.com/attachments/1333506116461662269/1423618986213511209/image.png?ex=69a761bf&is=69a6103f&hm=5a7c12a25fbc44f64336b91c3c87a07dc914f7738cca7236c0be116160b20ffb&",
            "https://cdn.discordapp.com/attachments/1333506116461662269/1423618986687332452/image.png?ex=69a761bf&is=69a6103f&hm=0a93ab39622d06ed4b19aea936cc0ee5e3d30c5a0b9df01bf3892275639b98f1&",
            "https://cdn.discordapp.com/attachments/1333506116461662269/1423618987115286578/image.png?ex=69a761c0&is=69a61040&hm=70570ca9d2ef99893167452ca9f66791ce394cd28a52314ecf7d962ea8f2b85a&",
            "https://cdn.discordapp.com/attachments/1333506116461662269/1428081147522322543/rusya_suriye.png?ex=69a7cb76&is=69a679f6&hm=98766c995e576a77036290cfa2b24fb5bd8ee1f0f6780be604af499d34008e9a"
        }
        
        self.currentBackground = 1
        self.nextBackground = 2
        self.fadeProgress = 1
        self.fadeSpeed = 0.5
        self.changeTimer = 0
        self.changeInterval = 5
        self.backgroundMaterials = {}
        self.accentColor = Color(255, 255, 255)
        self.currentLoadIndex = 1
        self.isLoading = false

        if not file.Exists("dezzaster/background", "DATA") then
            file.CreateDir("dezzaster/background")
        end

        for i = 1, #self.backgroundImages do
            local fileName = "dezzaster/background/bg_" .. i .. ".png"
            if file.Exists(fileName, "DATA") then
                self.backgroundMaterials[i] = Material("data/" .. fileName)
            end
        end

        if not self.backgroundMaterials[1] then
            self:LoadNextBackground()
        end

        self.Resizing = false
        self.ResizeDirection = nil
        self.MinWidth = 600
        self.MinHeight = 500
        self.ResizeMargin = 8
    end

    function PANEL:LoadNextBackground()
        if self.isLoading or self.currentLoadIndex > #self.backgroundImages then return end
        
        self.isLoading = true
        local i = self.currentLoadIndex
        local url = self.backgroundImages[i]
        local fileName = "dezzaster/background/bg_" .. i .. ".png"
        
        if file.Exists(fileName, "DATA") then
            self.backgroundMaterials[i] = Material("data/" .. fileName)
            self.currentLoadIndex = self.currentLoadIndex + 1
            self.isLoading = false
            self:LoadNextBackground()
            return
        end
        
        http.Fetch(url, function(body)
            if body and #body > 100 then
                file.Write(fileName, body)
                self.backgroundMaterials[i] = Material("data/" .. fileName)
            end
            
            self.currentLoadIndex = self.currentLoadIndex + 1
            self.isLoading = false
            
            timer.Simple(0.3, function()
                if IsValid(self) then
                    self:LoadNextBackground()
                end
            end)
            
        end, function(error)
            self.currentLoadIndex = self.currentLoadIndex + 1
            self.isLoading = false
            
            timer.Simple(0.3, function()
                if IsValid(self) then
                    self:LoadNextBackground()
                end
            end)
        end)
    end

    function PANEL:Think()
        for name, anim in pairs(self.Animations) do
            if anim:Active() then
                anim:Run()
            end
        end

        if table.Count(self.backgroundMaterials) > 0 then
            self.changeTimer = self.changeTimer + FrameTime()
            if self.changeTimer >= self.changeInterval then
                self.fadeProgress = 0
                self.currentBackground = self.nextBackground
                self.nextBackground = self.nextBackground + 1
                if self.nextBackground > #self.backgroundImages then
                    self.nextBackground = 1
                end
                
                while not self.backgroundMaterials[self.nextBackground] and self.nextBackground <= #self.backgroundImages do
                    self.nextBackground = self.nextBackground + 1
                    if self.nextBackground > #self.backgroundImages then
                        self.nextBackground = 1
                    end
                end
                
                self.changeTimer = 0
            end
            
            if self.fadeProgress < 1 then
                self.fadeProgress = math.min(self.fadeProgress + FrameTime() * self.fadeSpeed, 1)
            end
        end

        local x,y = input.GetCursorPos()
        local mousex = math.Clamp(x, 1, ScrW() - 1)
        local mousey = math.Clamp(y, 1, ScrH() - 1)

        if self.Dragging then
            local x = mousex - self.Dragging[1]
            local y = mousey - self.Dragging[2]
            self:SetPos(x, y)
        elseif self.Resizing then
            local newW, newH = self:GetWide(), self:GetTall()
            local deltaX = mousex - self.ResizeStartX
            local deltaY = mousey - self.ResizeStartY
            
            if self.ResizeDirection == "br" then
                newW = math.max(self.MinWidth, self.ResizeStartW + deltaX)
                newH = math.max(self.MinHeight, self.ResizeStartH + deltaY)
            elseif self.ResizeDirection == "bl" then
                newW = math.max(self.MinWidth, self.ResizeStartW - deltaX)
                newH = math.max(self.MinHeight, self.ResizeStartH + deltaY)
                if newW ~= self:GetWide() then
                    self:SetPos(self.ResizeStartX + deltaX, self.y)
                end
            elseif self.ResizeDirection == "tr" then
                newW = math.max(self.MinWidth, self.ResizeStartW + deltaX)
                newH = math.max(self.MinHeight, self.ResizeStartH - deltaY)
                if newH ~= self:GetTall() then
                    self:SetPos(self.x, self.ResizeStartY + deltaY)
                end
            elseif self.ResizeDirection == "tl" then
                newW = math.max(self.MinWidth, self.ResizeStartW - deltaX)
                newH = math.max(self.MinHeight, self.ResizeStartH - deltaY)
                if newW ~= self:GetWide() or newH ~= self:GetTall() then
                    self:SetPos(self.ResizeStartX + deltaX, self.ResizeStartY + deltaY)
                end
            end
            
            self:SetSize(newW, newH)
        end

        local cursor = "arrow"
        if self:IsInResizeArea(x, y) then
            local area = self:GetResizeArea(x, y)
            if area == "br" or area == "tl" then
                cursor = "sizenwse"
            elseif area == "bl" or area == "tr" then
                cursor = "sizenesw"
            end
        end
        
        self:SetCursor(cursor)
        
        if not self.Animations.ColorChange or not self.Animations.ColorChange:Active() then
            local target_color = HSVToColor((CurTime() * 20) % 360, 1, 1) or Color(255,255,255)
            target_color.r = math.Clamp(target_color.r, 150, 255)
            target_color.g = math.Clamp(target_color.g, 150, 255)
            target_color.b = math.Clamp(target_color.b, 150, 255)
            
            self.Animations.ColorChange = Derma_Anim("ColorChange", self, function(p, anim, delta, data)
                self.accentColor = LerpColor(delta, self.accentColor, target_color)
            end)
            self.Animations.ColorChange:Start(0.8)
        end
    end

    function PANEL:IsInResizeArea(x, y)
        local screenX, screenY = self:LocalToScreen(0, 0)
        local w, h = self:GetSize()
        
        local left = screenX
        local right = screenX + w
        local top = screenY
        local bottom = screenY + h
        
        return (x >= right - self.ResizeMargin and x <= right and y >= bottom - self.ResizeMargin and y <= bottom) or
               (x >= left and x <= left + self.ResizeMargin and y >= bottom - self.ResizeMargin and y <= bottom) or
               (x >= right - self.ResizeMargin and x <= right and y >= top and y <= top + self.ResizeMargin) or
               (x >= left and x <= left + self.ResizeMargin and y >= top and y <= top + self.ResizeMargin)
    end

    function PANEL:GetResizeArea(x, y)
        local screenX, screenY = self:LocalToScreen(0, 0)
        local w, h = self:GetSize()
        
        local left = screenX
        local right = screenX + w
        local top = screenY
        local bottom = screenY + h
        
        if x >= right - self.ResizeMargin and x <= right and y >= bottom - self.ResizeMargin and y <= bottom then
            return "br"
        elseif x >= left and x <= left + self.ResizeMargin and y >= bottom - self.ResizeMargin and y <= bottom then
            return "bl"
        elseif x >= right - self.ResizeMargin and x <= right and y >= top and y <= top + self.ResizeMargin then
            return "tr"
        elseif x >= left and x <= left + self.ResizeMargin and y >= top and y <= top + self.ResizeMargin then
            return "tl"
        end
        
        return nil
    end

    function PANEL:OnMousePressed()
        local x,y = input.GetCursorPos()
        local screenX, screenY = self:LocalToScreen(0, 0)

        if self:IsInResizeArea(x, y) then
            self.Resizing = true
            self.ResizeDirection = self:GetResizeArea(x, y)
            self.ResizeStartX = x
            self.ResizeStartY = y
            self.ResizeStartW = self:GetWide()
            self.ResizeStartH = self:GetTall()
            self:MouseCapture(true)
        else
            self.Dragging = {x - self.x, y - self.y}
            self:MouseCapture(true)
        end
    end

    function PANEL:OnMouseReleased()
        self.Dragging = nil
        self.Resizing = false
        self.ResizeDirection = nil
        self:MouseCapture(false)
    end

    function PANEL:Paint(w, h)
        if dezz.cfg.vars["background"] then
            if self.backgroundMaterials[self.currentBackground] then
                local currentAlpha = 255 * (1 - self.fadeProgress)
                surface.SetDrawColor(255, 255, 255, currentAlpha)
                surface.SetMaterial(self.backgroundMaterials[self.currentBackground])
                surface.DrawTexturedRect(0, 0, w, h)
            end
            
            if self.backgroundMaterials[self.nextBackground] then
                local nextAlpha = 255 * self.fadeProgress
                surface.SetDrawColor(255, 255, 255, nextAlpha)
                surface.SetMaterial(self.backgroundMaterials[self.nextBackground])
                surface.DrawTexturedRect(0, 0, w, h)
            end

