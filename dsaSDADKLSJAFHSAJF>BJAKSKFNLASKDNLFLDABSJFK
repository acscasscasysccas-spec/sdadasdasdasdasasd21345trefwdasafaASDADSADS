function dezz.CalcViewModelView(wep, vm, oldPos, oldAng, pos, ang)
    if wep.CalcViewModelView then wep.CalcViewModelView = nil end

    pos = dezz.vieworigin 
	ang = dezz.cfg.vars["Silent aim"] and dezz.SilentAngle or ang

    if dezz.cfg.vars["Viewmodel manip"] then
		local OverridePos = Vector(dezz.cfg.vars["Viewmodel x"], dezz.cfg.vars["Viewmodel y"], dezz.cfg.vars["Viewmodel z"])
		local OverrideAngle = Angle(dezz.cfg.vars["Viewmodel p"], dezz.cfg.vars["Viewmodel ya"], dezz.cfg.vars["Viewmodel r"])

		ang = ang * 1

		ang:RotateAroundAxis(ang:Right(), OverrideAngle.x * 1.0)
		ang:RotateAroundAxis(ang:Up(), OverrideAngle.y * 1.0)
		ang:RotateAroundAxis(ang:Forward(), OverrideAngle.z* 1.0)

		pos = pos + OverridePos.x * ang:Right() * 1.0
		pos = pos + OverridePos.y * ang:Forward() * 1.0
		pos = pos + OverridePos.z * ang:Up() * 1.0 
    end

	return pos, ang
end 
