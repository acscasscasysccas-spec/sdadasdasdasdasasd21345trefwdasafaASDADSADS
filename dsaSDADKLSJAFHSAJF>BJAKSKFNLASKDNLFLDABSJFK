GAMEMODE["EntityFireBullets"] = function( self, p, data ) 
    if not dezz.activeWeapon then return end

    local tick = engine.TickCount()
    if dezz.cfg.vars["On screen logs"] and data.Src == pLocalPlayer:EyePos() and dezz.aimingrn and dezz.target and not dezz.onScreenLogs[tick] and IsFirstTimePredicted() then
        local reason = 1
        
        local tr = util.TraceLine({
            start = data.Src,
            endpos = data.Src + data.Dir * 13337,
            filter = pLocalPlayer,
            mask = MASK_SHOT
        })
        
        if dezz.target.break_lc then
            reason = 4
        elseif ded.GetLatency(0) > 0.2 then
            reason = 3
        elseif tr.StartSolid or (tr.Hit and tr.Entity != dezz.target) then
            reason = 2
        end
        
        local hlcolor = string.ToColor(dezz.cfg.colors[dezz.MissReasons[reason].var])
        dezz.onScreenLogs[tick] = {
            tick = tick,
            {"Shot at ", dezz.target:Name(), " missed due to ", dezz.MissReasons[reason].str},
            {dezz.HitLogsWhite, hlcolor, dezz.HitLogsWhite, hlcolor}
        }
    end

    local spread = data.Spread * -1
    if dezz.cones[dezz.activeWeaponClass] != spread and spread != dezz.nullVec then
        dezz.cones[dezz.activeWeaponClass] = spread
    end
 
    local spread = data.Spread * -1
    
	if dezz.cones[ dezz.activeWeaponClass ] == spread or spread == dezz.nullVec then return end

    dezz.cones[ dezz.activeWeaponClass ] = spread;
end

function dezz.SetupWorldFog()
    if not dezz.cfg.vars[ "FogChanger" ] then return end 

    local color = string.ToColor(dezz.cfg.colors["FogChanger"])
    

    render.FogMode( MATERIAL_FOG_LINEAR )
    render.FogColor( color.r, color.g, color.b )
    render.FogStart( dezz.cfg.vars[ "FogStart" ] )
    render.FogEnd( dezz.cfg.vars[ "FogEnd" ] ) 
    render.FogMaxDensity( color.a / 255 )
    
    return true 
end

