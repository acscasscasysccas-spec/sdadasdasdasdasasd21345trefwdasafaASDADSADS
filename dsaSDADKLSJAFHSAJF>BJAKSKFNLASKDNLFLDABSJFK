local model_render = {overriden = false, old_blend = 0, old_color_r = 0, old_color_g = 0, old_color_b = 0}

function model_render:override(key, entity)
    if not dezz.cfg.vars[key .. " Override model render"] then
        return 
    end

    self.old_blend = render.GetBlend()
    self.old_color_r, self.old_color_g, self.old_color_b = render.GetColorModulation()

    entity:SetLOD(dezz.cfg.vars[key .. " Override model LOD"])

    render.SuppressEngineLighting(dezz.cfg.vars[key .. " Supress engine lighting"])

    if dezz.cfg.vars[key .. " Reset model lighting"] then
        local static_color = dezz.cfg.vars[key .. " Static lighting"]
        render.ResetModelLighting(static_color.r / 255, static_color.g / 255, static_color.b / 255)
    end

    if dezz.cfg.vars[key .. " Override model lighting"] then
        local shine_colors = dezz.cfg.vars[key .. " Shine"]
        for i = 1, 6 do
            local shine_color = shine_colors[i]
            render.SetModelLighting(i-1, shine_color.r / 255, shine_color.g / 255, shine_color.b / 255)
        end
    end

    render.SetBlend(dezz.cfg.vars[key .. " Override model blend"])

    local color_mod = dezz.cfg.vars[key .. " Override color modulation"]
    render.SetColorModulation(color_mod.r / 255, color_mod.g / 255, color_mod.b / 255)

    if dezz.cfg.vars[key .. " Ignore Z"] then
        render.DepthRange(0, 0)
    end
   
    local material_override = dezz.cfg.vars[key .. " Override material"]
    if material_override then
        render.MaterialOverride(materials[key])
    end

    self.overriden = true 
end

function model_render:restore()
    if not self.overriden then 
        return 
    end

    render.SuppressEngineLighting(false)
    render.SetBlend(self.old_blend)
    render.SetColorModulation(self.old_color_r, self.old_color_g, self.old_color_b)
    render.DepthRange(0, 1)
    render.MaterialOverride(nil)

    self.overriden = false 
end

function dezz.PrePlayerDraw(entity, flags)
    model_render:override(entity == pLocalPlayer and "Local player" or "Player", entity)

    if dezz.cfg.vars["Invalidate activity"] and entity ~= pLocalPlayer then
        entity:SetSequence(-1)
        entity:SetCycle(0)
        entity:SetPlaybackRate(0)
    end
    
    entity:InvalidateBoneCache()
    entity:SetupBones()
    entity.ChatGestureWeight = 0
end

function dezz.PostPlayerDraw(entity, flags)
    model_render:restore()
end

