function dezz.ParseBones( ply, bone )
    local mdl = ply:GetModel()

    if dezz.parsedbones[ mdl ] and dezz.parsedbones[ mdl ][ bone ] then 
        return dezz.parsedbones[ mdl ][ bone ]
    end

    if not dezz.parsedbones[ mdl ] then
        dezz.parsedbones[ mdl ] = {}
    end
        
    local set = ply:GetHitboxSet()
    local bonecount = ply:GetBoneCount()

    for i = 0, bonecount - 1 do 
		local group = ply:GetHitBoxHitGroup( i, set )

        if group == nil then continue end

		if bone == group then
			dezz.parsedbones[ mdl ][ bone ] = i

            return i
        end
	end

    for i = 0, bonecount - 1 do 
        local group = ply:GetHitBoxHitGroup( i, set )

        if group == nil then continue end

        if bone > 1 and group == 0 then
            dezz.parsedbones[ mdl ][ bone ] = i

            return i
        end
    end

    return 0
end

function dezz.MultipointGroupCheck( group )
    if group == 1 and not dezz.cfg.vars["Multipoint groups-Head"] then return false end
    if group == 2 and not dezz.cfg.vars["Multipoint groups-Chest"] then return false end
    if group == 3 and not dezz.cfg.vars["Multipoint groups-Stomach"] then return false end
    if group == 4 or group == 5 and not dezz.cfg.vars["Multipoint groups-Arms"] then return false end
    if group == 6 or group == 7 and not dezz.cfg.vars["Multipoint groups-Legs"] then return false end
    if group == 0 and not dezz.cfg.vars["Multipoint groups-Generic"] then return false end

    return true 
end

function dezz.GetBones(ply)
    local scale = dezz.cfg.vars["Multipoint scale"]
    local pos = ply:LocalToWorld(ply:OBBCenter())
    local set = ply:GetHitboxSet()

    if dezz.cfg.vars["Hitscan"] then
        local bonecount = ply:GetBoneCount()
        pos = {}

        for i = 0, bonecount - 1 do 
            local group = ply:GetHitBoxHitGroup(i, set)

            if group == nil then continue end

            if group == 1 and not dezz.cfg.vars["Hitscan groups-Head"] then continue end
            if group == 2 and not dezz.cfg.vars["Hitscan groups-Chest"] then continue end
            if group == 3 and not dezz.cfg.vars["Hitscan groups-Stomach"] then continue end
            if (group == 4 or group == 5) and not dezz.cfg.vars["Hitscan groups-Arms"] then continue end
            if (group == 6 or group == 7) and not dezz.cfg.vars["Hitscan groups-Legs"] then continue end
            if group == 0 and not dezz.cfg.vars["Hitscan groups-Generic"] then continue end

            pos[#pos + 1] = {bone = i, hitgroup = group}
        end

        if not pos or not istable(pos) then return end

        local valid = {}

        for k, v in ipairs(pos) do
            local bone = v.bone
            local hitboxbone = ply:GetHitBoxBone(bone, set)

            if hitboxbone == nil then 
                continue 
            end 

            local mins, maxs = ply:GetHitBoxBounds(bone, set)

            if not mins or not maxs then 
                continue
            end 

            local bonepos, ang = ply:GetBonePosition(hitboxbone)
            
            if dezz.cfg.vars["Multipoint"] and dezz.MultipointGroupCheck(v.hitgroup) then
                local points = {
                    ((mins + maxs) * 0.5),
                    Vector(mins.x, mins.y, mins.z),
                    Vector(mins.x, maxs.y, mins.z),
                    Vector(maxs.x, maxs.y, mins.z),
                    Vector(maxs.x, mins.y, mins.z),
                    Vector(maxs.x, maxs.y, maxs.z),
                    Vector(mins.x, maxs.y, maxs.z),
                    Vector(mins.x, mins.y, maxs.z),
                    Vector(maxs.x, mins.y, maxs.z)
                }

                for j = 1, #points do
                    points[j]:Rotate(ang)
                    points[j] = points[j] + bonepos

                    if j == 1 then continue end 

                    points[j] = ((points[j] - points[1]) * scale) + points[1]
                    valid[#valid + 1] = points[j]
                end
            end 

            mins:Rotate(ang)
            maxs:Rotate(ang)

            valid[#valid + 1] = bonepos + ((mins + maxs) * 0.5)
        end

        return valid
    else
        local bone = dezz.ParseBones(ply, dezz.cfg.vars["Hitbox selection"]) 
        local hitboxbone = ply:GetHitBoxBone(bone, set)

        if hitboxbone == nil then 
            return {pos}  
        end 

        local mins, maxs = ply:GetHitBoxBounds(bone, set)

        if not mins or not maxs then 
            return {pos} 
        end 

        local bonepos, ang = ply:GetBonePosition(hitboxbone)  

        if dezz.cfg.vars["Multipoint"] then
            local points = {
                ((mins + maxs) * 0.5),
                Vector(mins.x, mins.y, mins.z),
                Vector(mins.x, maxs.y, mins.z),
                Vector(maxs.x, maxs.y, mins.z),
                Vector(maxs.x, mins.y, mins.z),
                Vector(maxs.x, maxs.y, maxs.z),
                Vector(mins.x, maxs.y, maxs.z),
                Vector(mins.x, mins.y, maxs.z),
                Vector(maxs.x, mins.y, maxs.z)
            }

            for i = 1, #points do
                points[i]:Rotate(ang)
                points[i] = points[i] + bonepos

                if i == 1 then continue end 

                points[i] = ((points[i] - points[1]) * scale) + points[1]
            end

            return points
        else 
            mins:Rotate(ang)
            maxs:Rotate(ang)
            pos = bonepos + ((mins + maxs) * 0.5)
        end
    end

    return {pos}
end

function dezz.GetSortedPlayers( mode, selfpred, plypred, vischeck )
    local players   = player.GetAll()   
    local eyepos    = pLocalPlayer:EyePos()       
    local valid     = {}   

	if selfpred then
		eyepos = eyepos + (pLocalPlayer:GetVelocity() * flTickInterval) * selfpred
	end

    local iTeamLocal = dezz.GetTeam( pLocalPlayer )

    for i = 1, #players do
        local v = players[i]

        if v == pLocalPlayer then 
            continue 
        end 

        if not v:Alive() or v:IsDormant() then 
            continue 
        end

        if dezz.cfg.vars["Ignores-Bots"] and v:IsBot() then continue end 
        if dezz.cfg.vars["Ignores-Friends"] and dezz.cfg.friends[v:SteamID()] then continue end 
        if dezz.cfg.vars["Ignores-Steam friends"] and v:GetFriendStatus() == "friend" then continue end 
        if dezz.cfg.vars["Ignores-Admins"] and dezz.cfg.admins[v:SteamID()] or v:IsAdmin() then continue end 
        if dezz.cfg.vars["Ignores-Frozen"] and v:IsFlagSet( FL_FROZEN ) then continue end 
        if dezz.cfg.vars["Ignores-Nodraw"] and v:IsEffectActive( EF_NODRAW ) then continue end 
        if dezz.cfg.vars["Ignores-God time"] and v:GetColor().a < 255 then continue end 
        if dezz.cfg.vars["Ignores-Driver"] and v:InVehicle() then continue end 
        if dezz.cfg.vars["Target-Priority-Only"] and not dezz.cfg.priorityList[v:SteamID()] then continue end

        local iTeamEnemy = dezz.GetTeam( v )

        if st == TEAM_SPECTATOR or dezz.cfg.vars["Ignores-Teammates"] and iTeamLocal == iTeamEnemy then 
            continue 
        end 

        if dezz.cfg.vars["Ignores-Nocliping"] and v:GetMoveType() == MOVETYPE_NOCLIP then 
            continue 
        end 

        if vischeck then
			local bone = dezz.GetBones( v )[1]
			local dir = pLocalPlayer:GetShootPos() - bone
			dir:Normalize()

			if !dezz.VisibleCheck( v, bone, selfpred, dir ) then
				continue
			end
		end

        local pos = v:GetPos()
        if plypred then 
            pos = pos + (v:GetVelocity() * flTickInterval) * plypred
        end

        valid[#valid+1] = { v, pos }
    end

    if mode == 1 then
        table.sort(valid, function( a, b )
            return ( a[2] - eyepos ):LengthSqr() < ( b[2] - eyepos ):LengthSqr()       
        end)
    elseif mode == 2 then
        table.sort(valid, function( a, b )
            local aScr, bScr = a[2]:ToScreen(), b[2]:ToScreen()

            local aDist
            do
                local dx = ( screenWidth * 0.5 ) - aScr.x
                local dy = ( screenHeight * 0.5 ) - aScr.y
                aDist = dx * dx + dy * dy
            end
    
            local bDist
            do
                local dx = ( screenWidth * 0.5 ) - bScr.x
                local dy = ( screenHeight * 0.5 ) - bScr.y
                bDist = dx * dx + dy * dy
            end
    
            return aDist < bDist
        end)
    end

    if #valid == 0 then return end

    return valid
end

function dezz.IsTickHittable( ply, cmd, tick )
    if ded.GetLatency(0) > 1 then return false end

    local serverArriveTick = dezz.flServerTime + ded.GetLatency(0) + ded.GetLatency(1)
    local diff = serverArriveTick - dezz.btrecords[ ply ][ tick ].simulationtime

    if diff > dezz.cfg.vars["Backtrack time"] / 1000 then return false end

    return true
end

function dezz.FindBacktrack( cmd, ply )
    local ticks = #dezz.btrecords[ ply ]
    local canhit = {}

    for i = 1, ticks do
        if dezz.IsTickHittable( ply, cmd, i ) then
            canhit[ #canhit + 1 ] = i
        end
    end

    return canhit
end

function dezz.FindFirstHittableTicks( ply, cmd )
    local tickcount = #dezz.btrecords[ ply ]

    if !tickcount then return 1 end

    for i = 1, tickcount do
        if dezz.IsTickHittable( ply, cmd, i ) then
            return i
        end
    end
end

do
    local lastdist, lasttick = 1337, 1

    function dezz.FindClosestHittableTicks( ply, cmd )
        local mypos = pLocalPlayer:EyePos()
        local records = dezz.btrecords[ ply ]
        local firstticks = dezz.FindFirstHittableTicks( ply, cmd )
        local tickcount = #records

        if !tickcount or !firstticks then return 1 end

        lastdist = math.huge
    
        for i = 1, tickcount - firstticks do
            local mt = i + firstticks

            if ( records[ mt ].aimpos ):DistToSqr( mypos ) < lastdist then
                lastdist = ( records[ mt ].aimpos ):DistToSqr( mypos )
                lasttick = mt
            end
        end

        return lasttick
    end
end

function dezz.SelectTarget( cmd )
    local plys = dezz.GetSortedPlayers( dezz.cfg.vars["Target selection"] )
    dezz.target     = false


    if !plys then return end 

    local maxplys       = dezz.cfg.vars["Max targets"]
    local curplys       = #plys

    if maxplys != 0 and curplys > maxplys then
        curplys = maxplys
    end

    local vEyePos = pLocalPlayer:EyePos()

    local aimAng
    for i = 1, curplys do
		local ply = plys[i][1]

        -- distance check 
        local iMaxDistance = dezz.cfg.vars[ "Max distance" ]
        local iDistance = vEyePos:DistToSqr( ply:EyePos() )

        if ( iMaxDistance != 0 and iDistance > ( iMaxDistance * iMaxDistance ) ) then
            continue 
        end
        






        if not dezz.cfg.vars["Always backtrack"] then
            local bones = dezz.GetBones( ply )

            for o = 1, #bones do
                local bone = bones[o]
                aimAng = ( bone - pLocalPlayer:EyePos() ):Angle()

                if dezz.VisibleCheck( ply, bone, nil, aimAng:Forward() ) then 
                    dezz.target = ply
                    return ply, bone, aimAng, false, 0
                end
            end

        elseif dezz.cfg.vars["Extrapolation"] and dezz.predicted[ ply ] then
            if not dezz.predicted[ ply ].pos then return end

            aimAng = ( dezz.predicted[ ply ].pos - pLocalPlayer:EyePos() ):Angle()

            dezz.traceStruct.start = pLocalPlayer:EyePos()
            dezz.traceStruct.endpos = dezz.predicted[ ply ].pos
            dezz.traceStruct.filter = pLocalPlayer
            dezz.traceStruct.mask = MASK_SHOT

            local tr = TraceLine( dezz.traceStruct )

            if !tr.Hit or tr.Entity == ply then
                dezz.target = ply
                return ply, dezz.predicted[ ply ].pos, aimAng, false, 0
            end
        end

        if dezz.cfg.vars["Backtrack"] then
            local ticks = dezz.FindBacktrack( cmd, ply )

            if dezz.btrecords[ ply ] and not ply.break_lc then 
                local ts = 0 
                
                if dezz.cfg.vars["Backtrack mode"] == 3 then
                    for p = 1, #ticks do
                        if not dezz.btrecords[ ply ][ p ] then continue end

                        aimAng = ( dezz.btrecords[ ply ][ p ].aimpos - pLocalPlayer:EyePos() ):Angle()

                        dezz.traceStruct.start = pLocalPlayer:EyePos()
                        dezz.traceStruct.endpos = dezz.btrecords[ ply ][ p ].aimpos
                        dezz.traceStruct.filter = pLocalPlayer
                        dezz.traceStruct.mask = MASK_SHOT

                        local tr = TraceLine( dezz.traceStruct )

                        if !tr.Hit or tr.Entity == ply then
                            dezz.target = ply
                            dezz.backtracktick = p

                            return ply, dezz.btrecords[ ply ][ p ].aimpos, aimAng, true, p
                        end
                    end
                end

                if dezz.cfg.vars["Backtrack mode"] == 3 then return end
                if dezz.cfg.vars["Backtrack mode"] == 1 then
                    ts = dezz.FindFirstHittableTicks( ply, cmd )
                elseif dezz.cfg.vars["Backtrack mode"] == 2 then
                    ts = dezz.FindClosestHittableTicks( ply, cmd )
                end

                if not dezz.btrecords[ ply ][ ts ] then return end

                aimAng = ( dezz.btrecords[ ply ][ ts ].aimpos - pLocalPlayer:EyePos() ):Angle()

                dezz.traceStruct.start = pLocalPlayer:EyePos()
                dezz.traceStruct.endpos = dezz.btrecords[ ply ][ ts ].aimpos
                dezz.traceStruct.filter = pLocalPlayer
                dezz.traceStruct.mask = MASK_SHOT

                local tr = TraceLine( dezz.traceStruct )

                if !tr.Hit or tr.Entity == ply then
                    dezz.target = ply
                    dezz.backtracktick = ts

                    return ply, dezz.btrecords[ ply ][ ts ].aimpos, aimAng, true, ts
                end
            end
        end
	end
end

