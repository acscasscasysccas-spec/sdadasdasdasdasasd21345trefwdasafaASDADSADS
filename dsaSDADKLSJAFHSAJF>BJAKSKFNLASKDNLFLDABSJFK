dezz.spfuncs[35] = function(p)
    local mdl = vgui.Create("DModelPanel", p)
    mdl:SetPos(50, 50)
    mdl:SetSize(150, 200)
    mdl:SetModel("models/player/Group01/male_07.mdl")
    mdl:SetCamPos(Vector(50, 0, 66))
    mdl:SetLookAt(Vector(0, 0, 66))
    mdl:SetCursor("hand")

    for i = 1, 4 do
        if dezz.esppans[i] and dezz.esppans[i].panel and IsValid(dezz.esppans[i].panel) then
            dezz.esppans[i].panel:Remove()
        end
    end

    for i = 1, 4 do
        local poses = dezz.esppansposes
        dezz.esppans[i] = dezz.esppans[i] or {}

        dezz.esppans[i].panel = vgui.Create("UPaintedPanel", p)
        dezz.esppans[i].panel:SetPos(poses[i].x, poses[i].y)
        dezz.esppans[i].panel:SetSize(85, 125)
        dezz.esppans[i].panel:Receiver("SwagCock$", dezz.DoDrop)
        dezz.esppans[i].panel.pos = i
        
        dezz.esppans[i].panel.Paint = function(self, w, h)
            draw.RoundedBox(4, 0, 0, w, h, Color(43, 0, 0, 220))
        end
    end

    for i = 1, #dezz.espelements do
        local cfgstr = dezz.espelements[i]
        local enabledVar = cfgstr:gsub(" pos", "")

        if dezz.cfg and dezz.cfg.vars and dezz.cfg.vars[enabledVar] == true then
            local panelIndex = dezz.cfg.vars[cfgstr] or 1
            
            if panelIndex >= 1 and panelIndex <= 4 and dezz.esppans[panelIndex] and dezz.esppans[panelIndex].panel then
                local panel = dezz.esppans[panelIndex].panel
                
                local b = vgui.Create("DButton", panel)
                b:SetText(enabledVar)
                b:SetSize(75, 24)
                b:Dock(TOP)
                b:DockMargin(5, 2, 5, 2)
                b:Droppable("SwagCock$")
                b.elementName = cfgstr
                b:SetTextColor(Color(255, 255, 255))
                b.Paint = function(self, w, h)
                    draw.RoundedBox(4, 0, 0, w, h, Color(58, 0, 0, 240))
                    if self:IsHovered() then
                        draw.RoundedBox(4, 0, 0, w, h, Color(63, 6, 6, 240))
                    end
                end
            end
        end
    end
end

