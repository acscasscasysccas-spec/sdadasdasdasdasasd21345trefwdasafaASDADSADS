    function dezz.DrawPlayersHitboxes()
        if not dezz.cfg.vars["Hitbox"] then return end
        if not pLocalPlayer:Alive() then return end
        if dezz.hideHitboxes then return end 
        
        local hitbox_color = string.ToColor(dezz.cfg.colors["Hitbox"])
        local eye_pos, eye_ang = EyePos(), EyeAngles()
        
        cam.Start3D(eye_pos, eye_ang)
        
        for _, ply in ipairs(player.GetAll()) do
            if not IsValid(ply) or not ply:Alive() then continue end
            
            if not ply.fakeModel then
                ply.fakeModel = dezz.CS_Model(ply:GetModel())
                ply.lastModel = ply:GetModel()
            end
            
            if ply:GetModel() != ply.lastModel then
                if IsValid(ply.fakeModel) then
                    ply.fakeModel:Remove()
                end
                ply.fakeModel = dezz.CS_Model(ply:GetModel())
                ply.lastModel = ply:GetModel()
            end
            
            if not IsValid(ply.fakeModel) then continue end
            
            local tbl = {
                layers = dezz.fakeAngles and dezz.fakeAngles.layers,
                angles = ply:EyeAngles(),
                sequence = ply:GetSequence(),
                cycle = ply:GetCycle(),
                origin = ply:GetPos(),
