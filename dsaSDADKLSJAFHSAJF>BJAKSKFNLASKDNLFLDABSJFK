    if dezz.cfg.vars["Resolver"] and hurted:IsPlayer() and hurted != pLocalPlayer then
        dezz._resolver_success = dezz._resolver_success or {}
        
        if IsValid(hurted) then
            local mode = dezz.cfg.vars["Resolver type"] or "Absolute"
            local base = hurted._last_offset or 0
            local shots = hurted.aimshots or 0
            local rand = math.random(-22, 22)

            if dezz.cfg.vars["Adaptive resolver"] and mode != "HVH" then
                local vel = (hurted.GetVelocity and hurted:GetVelocity():Length2D()) or 0
                local crouch = (hurted.Crouching and hurted:Crouching()) or false
                if not (hurted.IsOnGround and hurted:IsOnGround()) then
                    dezz._resolver_success[hurted] = base + ((shots % 2 == 0) and 90 or -90)
                elseif vel > 120 and not crouch then
                    dezz._resolver_success[hurted] = base + ((shots % 3 == 0) and 45 or -45) + rand
                elseif crouch and vel < 10 then
                    dezz._resolver_success[hurted] = base + ((shots % 2 == 0) and 15 or -15)
                else
                    dezz._resolver_success[hurted] = base + ((shots % 4 == 0) and 180 or 0)
                end
            elseif mode == "HVH" then
                local tick = engine.TickCount()
                local success_pattern = (tick % 5) + 1
                local success_offsets = { -60, -30, 0, 30, 60, -120, 120 }
                dezz._resolver_success[hurted] = base + success_offsets[success_pattern]
            else
                if mode == "Absolute" then
                    dezz._resolver_success[hurted] = (shots % 2 == 0) and 0 or 180
                elseif mode == "Rage" then
                    dezz._resolver_success[hurted] = base + ((shots % 3 == 0) and 45 or -45) + rand
                elseif mode == "Delta" then
                    if hurted.GetVelocity then
                        local vel = hurted:GetVelocity()
                        local moveYaw = vel:Angle().yaw
                        dezz._resolver_success[hurted] = moveYaw + rand
                    else
                        dezz._resolver_success[hurted] = base + rand
                    end
                elseif mode == "Legit" then
                        if hurted.GetVelocity then
                        local vel = hurted:GetVelocity()
                        local moveYaw = vel:Angle().yaw
                        dezz._resolver_success[hurted] = moveYaw + rand
                    else
                        dezz._resolver_success[hurted] = base + rand
                    end
                elseif mode == "Experimental" then
                    dezz._resolver_success[hurted] = base + math.sin(CurTime() * 4 + shots) * 60
                else
                    dezz._resolver_success[hurted] = base + ((shots % 2 == 0) and 58 or -58) + math.random(-30, 30)
                end
            end
            hurted.aimshots = 0
                end
            end
        end)
    end
end


