function dezz.AutoWall( dir, plyTarget )
	if not dezz.activeWeapon or dezz.swbShit[ dezz.activeWeaponClass ] then return false end 

	local eyePos = pLocalPlayer:EyePos()
	
	local function SWBAutowall()

        dezz.traceStruct.start = eyePos
        dezz.traceStruct.endpos = eyePos + dir * dezz.activeWeapon.PenetrativeRange
        dezz.traceStruct.filter = pLocalPlayer
        dezz.traceStruct.mask = dezz.swbNormal

		local tr = TraceLine( dezz.traceStruct )
		
		if tr.Hit and !tr.HitSky then
			local dot = -dir:Dot(tr.HitNormal)
			
			if dezz.activeWeapon.CanPenetrate and dot > 0.26 then

                dezz.traceStruct.start = tr.HitPos
                dezz.traceStruct.endpos = tr.HitPos + dir * dezz.activeWeapon.PenStr * ( dezz.swbPen[tr.MatType] or 1 ) * dezz.activeWeapon.PenMod
                dezz.traceStruct.filter = pLocalPlayer
                dezz.traceStruct.mask = dezz.swbWall

				tr = TraceLine( dezz.traceStruct )

                dezz.traceStruct.start = tr.HitPos
                dezz.traceStruct.endpos = tr.HitPos + dir * 0.1
                dezz.traceStruct.filter = pLocalPlayer
                dezz.traceStruct.mask = dezz.swbNormal

				tr = TraceLine( dezz.traceStruct) 
				
				if tr.Hit then return false end

                dezz.traceStruct.start = tr.HitPos
                dezz.traceStruct.endpos = tr.HitPos + dir * 32768
                dezz.traceStruct.filter = pLocalPlayer
                dezz.traceStruct.mask = MASK_SHOT

				tr = TraceLine( dezz.traceStruct )
				
                if dezz.cfg.vars["Ignores-Head unhitable"] then
                    return tr.Entity == plyTarget and tr.HitGroup == 1
                else
                    return tr.Entity == plyTarget
                end
			end
		end
		
		return false
	end
	
	local function M9KAutowall()
        local penetrate_cvar = GetConVar( "M9KDisablePenetration" )
        if IsValid(penetrate_cvar) then
            if ( penetrate_cvar:GetBool() ) then
                return false 
            end
        end

		if !dezz.activeWeapon.Penetration then
			return false
		end

		local function BulletPenetrate( tr, bounceNum, damage )
			if damage < 1 then
				return false
			end
			
			local maxPenetration    = 14
            local maxRicochet       = 0
            local isRicochet        = false

            if dezz.m9kPenetration[ dezz.activeWeapon.Primary.Ammo ] then
                maxPenetration = dezz.m9kPenetration[ dezz.activeWeapon.Primary.Ammo ]
            end
			
            if dezz.m9kMaxRicochet[ dezz.activeWeapon.Primary.Ammo ] then
                maxRicochet = dezz.m9kMaxRicochet[ dezz.activeWeapon.Primary.Ammo ]
            end

            if dezz.m9kCanRicochet[ dezz.activeWeapon.Primary.Ammo ] then
                isRicochet = dezz.m9kMaxRicochet[ dezz.activeWeapon.Primary.Ammo ]
            end

			if tr.MatType == MAT_METAL and isRicochet and dezz.activeWeapon.Primary.Ammo != "SniperPenetratedRound" then
				return false
			end

			if bounceNum > maxRicochet then
				return false
			end

			local penetrationDir = tr.Normal * maxPenetration

			if dezz.m9kPenMaterial[ tr.MatType ] then
				penetrationDir = tr.Normal * ( maxPenetration * 2 ) 
			end

			if tr.Fraction <= 0 then
				return false
			end

			dezz.traceStruct.endpos    = tr.HitPos
			dezz.traceStruct.start     = tr.HitPos + penetrationDir
			dezz.traceStruct.mask      = MASK_SHOT
			dezz.traceStruct.filter    = pLocalPlayer

			local trace = TraceLine( dezz.traceStruct )

			if trace.StartSolid or trace.Fraction >= 1 then
				return false
			end

			dezz.traceStruct.endpos = trace.HitPos + tr.Normal * 32768
			dezz.traceStruct.start  = trace.HitPos
			dezz.traceStruct.mask   = MASK_SHOT
			dezz.traceStruct.filter = pLocalPlayer

			local penTrace = TraceLine( dezz.traceStruct )

            if dezz.cfg.vars["Ignores-Head unhitable"] then
                return penTrace.Entity == plyTarget and penTrace.HitGroup == 1
            else
                return penTrace.Entity == plyTarget
            end

			local damageMulti = 0.5
			if dezz.activeWeapon.Primary.Ammo == "SniperPenetratedRound" then
				damageMulti = 1
			elseif tr.MatType == MAT_CONCRETE or tr.MatType == MAT_METAL then
				damageMulti = 0.3
			elseif tr.MatType == MAT_WOOD or tr.MatType == MAT_PLASTIC or tr.MatType == MAT_GLASS then
				damageMulti = 0.8
			elseif tr.MatType == MAT_FLESH or tr.MatType == MAT_ALIENFLESH then
				damageMulti = 0.9
			end
			
			if penTrace.MatType == MAT_GLASS then
				bounceNum = bounceNum - 1
			end

			return BulletPenetrate( penTrace, bounceNum + 1, damage * damageMulti )
		end

        dezz.traceStruct.start = eyePos
        dezz.traceStruct.endpos = eyePos + dir * 32768
        dezz.traceStruct.filter = pLocalPlayer
        dezz.traceStruct.mask = MASK_SHOT

		local trace = TraceLine( dezz.traceStruct )

		return BulletPenetrate( trace, 0, dezz.activeWeapon.Primary.Damage )
	end
	
    if string.StartsWith( dezz.activeWeaponClass, "m9k_" ) or string.StartsWith( dezz.activeWeaponClass, "bender_" ) then
		return M9KAutowall()
	elseif string.StartsWith( dezz.activeWeaponClass, "swb_" ) then
		return SWBAutowall()
	end
	
	return false
end

function dezz.VisibleCheck( who, where, predticks, awalldir )
    local start = pLocalPlayer:EyePos()

    if predticks then start = start + ( pLocalPlayer:GetVelocity() * flTickInterval ) * predticks end

    dezz.traceStruct.start = start
	dezz.traceStruct.endpos = where
	dezz.traceStruct.mask = MASK_SHOT
    dezz.traceStruct.filter = pLocalPlayer

    local tr = TraceLine( dezz.traceStruct )

    local canhit = tr.Entity == who or tr.Fraction == 1

    if !canhit and awalldir and dezz.cfg.vars["Wallz"] then 
        return dezz.AutoWall( awalldir, who )
    end

    if dezz.cfg.vars["Ignores-Head unhitable"] and tr.HitGroup != 1 then return false end

    return canhit
end

