                    for i = 1, simpleSegments do
                        local theta1 = ((i - 1) / simpleSegments) * 2 * math.pi
                        local theta2 = (i / simpleSegments) * 2 * math.pi

                        local x1 = math.cos(theta1) * radius
                        local y1 = math.sin(theta1) * radius
                        local x2 = math.cos(theta2) * radius
                        local y2 = math.sin(theta2) * radius

                        local pos1 = centerPos + Vector(x1, y1, 0)
                        local pos2 = centerPos + Vector(x2, y2, 0)

                        render.DrawLine(pos1, pos2, color, false)
                    end
                end
            cam.End3D()

            if dezz.IsKeyDown(dezz.cfg.binds["Panic Key"]) then
                hook.Remove("PostDrawTranslucentRenderables", "DrawKnifebotRange")
            end
        end)

