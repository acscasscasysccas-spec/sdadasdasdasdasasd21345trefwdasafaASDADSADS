function dezz.PulseRifleAltPred(cmd)
    if not dezz.CanShoot(cmd) then return end

    local plys = dezz.GetSortedPlayers(dezz.cfg.vars["Target selection"])
    if not plys or #plys == 0 then return end

    local weapon = LocalPlayer():GetActiveWeapon()
    if not IsValid(weapon) then return end

    local bulletSpeed = 1200
    local bulletGravity = 0.1
    local bulletDrop = GetConVar("sv_gravity"):GetFloat() * bulletGravity

    local ballRadius = 20

    for i = 1, #plys do
        local ply = plys[i][1]
        if not IsValid(ply) then continue end

        local eyePos = LocalPlayer():EyePos()
        local plyPos = ply:GetPos()
        local plyCenter = ply:OBBCenter()
        local plyVel = ply:GetVelocity()

        local aimPos = plyPos + plyCenter
        local distance = eyePos:Distance(aimPos)
        local travelTime = distance / bulletSpeed

        local predTime = travelTime + engine.TickInterval() * 2

        if ded and ded.StartSimulation then
            ded.StartSimulation(ply:EntIndex())
            local ticks = math.ceil(predTime / engine.TickInterval())
            for j = 1, math.min(ticks, 10) do
                ded.SimulateTick()
            end
            local data = ded.GetSimulationData()
            if data and data.m_vecAbsOrigin then
                aimPos = data.m_vecAbsOrigin + plyCenter
            end
            ded.FinishSimulation()
        else
            aimPos = aimPos + plyVel * travelTime
        end

        distance = eyePos:Distance(aimPos)
        travelTime = distance / bulletSpeed

        local gravityDrop = 0.5 * bulletDrop * travelTime * travelTime
        aimPos.z = aimPos.z + gravityDrop * 0.2

        if plyVel:Length() > 10 then
            local velFactor = 0.8
            aimPos = aimPos + plyVel * travelTime * velFactor
        end

        local trace = util.TraceLine({
            start = eyePos,
            endpos = aimPos,
            filter = {LocalPlayer(), ply},
            mask = MASK_SOLID
        })

        if trace.Hit and trace.Entity ~= ply and trace.Fraction < 0.95 then
            local upPos = aimPos + Vector(0, 0, 30)
            local downPos = aimPos - Vector(0, 0, 30)
            
            local traceUp = util.TraceLine({start = eyePos, endpos = upPos, filter = LocalPlayer()})
            local traceDown = util.TraceLine({start = eyePos, endpos = downPos, filter = LocalPlayer()})
            
            if not traceUp.Hit then
                aimPos = upPos
            elseif not traceDown.Hit then
                aimPos = downPos
            else
                continue
            end
        end

        local finalAng = (aimPos - eyePos):Angle()
        finalAng:Normalize()

        cmd:SetViewAngles(finalAng)
        cmd:SetButtons(bit.bor(cmd:GetButtons(), IN_ATTACK2))
        break
    end
end


