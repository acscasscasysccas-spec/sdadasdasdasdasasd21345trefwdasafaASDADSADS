local pitches = { 
    [1] = 89,
    [2] = -89,
    [3] = 0,
    [4] = -180,
    [5] = 180,
}

local mm_side = false
local pitchflip = false

local function CalcPitch()
    local cfg = dezz.cfg.vars["Pitch"] or 1
    local x = 0

    if cfg <= 5 then return pitches[cfg] or 0 end

    if dezz.SendPacket then
        pitchflip = not pitchflip
    end
    
    if cfg == 6 then
        x = pitchflip and 180 or -180
    elseif cfg == 7 then
        x = pitchflip and -180 or 271
    elseif cfg == 8 then
        x = math.random() > 0.5 and math.random(-180, 95) or math.random(177, 180)
    elseif cfg == 9 then
        x = math.random() > 0.5 and math.random(-180, -55) or math.random(55, 180)
    elseif cfg == 10 then
        x = math.random() > 0.5 and math.random(180, 95) or math.random(-180, -95)
    elseif cfg == 11 then
        x = math.random() > 0.5 and math.random(-180, -95) or math.random(166, 181)
    elseif cfg == 12 then
        x = math.random() > 0.5 and math.random(-180, -115) or math.random(177, 181)
    elseif cfg == 13 then
        x = pitchflip and -180 or 271
    elseif cfg == 14 then    
        x = dezz.cfg.vars["Custom pitch"] or 0
    end

    return x
end

local function micromovement(cmd)
    if not dezz.cfg.vars["Micromovement"] then return end
    if not IsValid(pLocalPlayer) or not pLocalPlayer:Alive() then return end
    if not pLocalPlayer:IsOnGround() then return end
    if cmd:KeyDown(IN_BACK) or cmd:KeyDown(IN_FORWARD) or cmd:KeyDown(IN_MOVELEFT) or cmd:KeyDown(IN_MOVERIGHT) then return end

    cmd:SetSideMove(mm_side and -15.0 or 15.0)
    mm_side = not mm_side
end

